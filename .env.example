# Bazzar Terminal — data layer credentials (copy to .env and fill in; .env is
# gitignored and must NEVER be committed).
#
# Market data flows through a self-hosted OpenAlgo instance with the Motilal
# Oswal broker. See:
# https://github.com/marketcalls/openalgo-docs/blob/main/connect-brokers/brokers/motilal-oswal.md

# OpenAlgo host base URL (local OpenAlgo server).
OPENALGO_BASE_URL=http://127.0.0.1:5000

# OpenAlgo host API key (from the OpenAlgo dashboard).
OPENALGO_API_KEY=

# Motilal Oswal broker credentials: BROKER_API_KEY is your Motilal client code,
# BROKER_API_SECRET is the generated API key from the Motilal Oswal API portal.
BROKER_API_KEY=
BROKER_API_SECRET=

# Bazzar data directory (holds bazzar.duckdb and the chart cache; gitignored).
BAZZAR_DATA_DIR=./data

# Local API port for `python3 -m backend.server`.
BAZZAR_API_PORT=8787
